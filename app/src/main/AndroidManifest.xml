<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PresentationApp">

        <activity
            android:name="org.pedrov.presentationtimer.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustPan">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="org.pedrov.presentationtimer.SettingsActivity"
            android:exported="false"
            android:parentActivityName="org.pedrov.presentationtimer.MainActivity"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name="org.pedrov.presentationtimer.AboutActivity"
            android:exported="false"
            android:parentActivityName="org.pedrov.presentationtimer.SettingsActivity" />

    </application>

</manifest>
