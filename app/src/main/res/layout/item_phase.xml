<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/surface_container_high"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Name + delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Phase name"
                app:hintTextColor="@color/outline"
                app:boxStrokeColor="@color/outline_variant"
                app:boxBackgroundColor="@color/surface_container">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/manrope" />
            </com.google.android.material.textfield.TextInputLayout>

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Delete phase"
                android:tint="#EF5350" />

        </LinearLayout>

        <!-- Threshold % — live slider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ACTIVE WHEN ≥"
                android:textSize="9sp"
                android:textColor="@color/outline"
                android:fontFamily="@font/manrope"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tvThresholdValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50%"
                android:textSize="14sp"
                android:textColor="@color/primary"
                android:fontFamily="@font/space_grotesk"
                android:textStyle="bold" />

        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderThreshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginStart="-8dp"
            android:layout_marginEnd="-8dp"
            android:valueFrom="0"
            android:valueTo="100"
            android:stepSize="1"
            app:thumbColor="@color/primary"
            app:trackColorActive="@color/primary"
            app:trackColorInactive="@color/outline_variant"
            app:thumbRadius="10dp"
            app:labelBehavior="gone" />

        <!-- Message -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Message shown during this phase"
            app:hintTextColor="@color/outline"
            app:boxStrokeColor="@color/outline_variant"
            app:boxBackgroundColor="@color/surface_container">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textColor="@color/on_surface"
                android:fontFamily="@font/manrope" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Color label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="BACKGROUND COLOR"
            android:textSize="9sp"
            android:fontFamily="@font/manrope"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:textColor="@color/outline" />

        <!-- Color swatches -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/colorSwatches"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp" />

        </HorizontalScrollView>

    </LinearLayout>

</androidx.cardview.widget.CardView>
